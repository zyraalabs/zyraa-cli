{
  "name": "zyraa",
  "version": "1.2.1",
  "description": "Terminal-based full stack code generation tool",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "zyraa": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --outDir dist --external react --external ink --minify",
    "dev": "CLI_BACKEND_URL=http://localhost:4000 ZYRAA_DASHBOARD_URL=http://localhost:3002 tsx watch src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "cli",
    "code-generation",
    "fullstack"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.2",
    "chalk": "^5.3.0",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.1",
    "tsup": "^8.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.0.0"
  }
}
